{
  "name": "managed-agents",
  "description": "AgentStep Gateway — self-hosted Anthropic Managed Agents-compatible API",
  "private": true,
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/agentstep/gateway.git" },
  "homepage": "https://www.agentstep.com",
  "bugs": { "url": "https://github.com/agentstep/gateway/issues" },
  "workspaces": [
    "packages/agent-sdk",
    "packages/gateway",
    "packages/gateway-hono",
    "packages/gateway-ui"
  ],
  "scripts": {
    "dev": "npm run dev -w @agentstep/gateway-hono",
    "build": "npm run build -w @agentstep/agent-sdk && npm run build -w @agentstep/gateway",
    "test": "npm test -w @agentstep/agent-sdk && npm test -w @agentstep/gateway",
    "typecheck": "npm run typecheck -w @agentstep/agent-sdk",
    "build:ui": "npm run build -w @agentstep/gateway-ui && npx tsx scripts/build-ui.ts"
  },
  "dependencies": {
    "@vercel/sandbox": "^1.9.3",
    "e2b": "^2.19.0",
    "marked": "^18.0.0",
    "modal": "^0.7.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.1.4"
  },
  "version": "0.4.16"
}
