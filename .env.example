# AgentStep Gateway — environment variables.
#
# Copy to .env and fill in what you need. The gateway will auto-generate
# SEED_API_KEY and VAULT_ENCRYPTION_KEY on first run if they're missing.

# ─── Auth / storage (auto-generated if unset) ─────────────────────────────

# API key the server seeds on first boot. Written to .env by the gateway
# if not set here. The CLI and web UI will use this key for all calls.
# SEED_API_KEY=ck_...

# Per-instance key used to encrypt vault entries (AES-256-GCM).
# Generated on first vault write if unset. Losing this key makes all
# vault entries unrecoverable — back up .env.
# VAULT_ENCRYPTION_KEY=...

# Local SQLite path. Default is ./data/managed-agents.db, relative to CWD.
# DATABASE_PATH=./data/managed-agents.db

# Turso embedded replica mode — syncs local SQLite with a remote Turso DB.
# If set, `gateway db reset` refuses to run (would be undone by next sync).
# TURSO_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=...

# ─── Agent engine credentials ─────────────────────────────────────────────

# ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# FACTORY_API_KEY=...
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-...    # Claude engine only, alternative to API key

# ─── Sandbox provider credentials ─────────────────────────────────────────

# SPRITE_TOKEN=org/user/project/token       # Sprites.dev (default cloud provider)
# E2B_API_KEY=e2b_...
# DAYTONA_API_KEY=...

# Vercel (needs all three)
# VERCEL_TOKEN=...
# VERCEL_TEAM_ID=...
# VERCEL_PROJECT_ID=...

# Fly.io (needs both)
# FLY_API_TOKEN=fo1_...
# FLY_APP_NAME=...

# Modal (needs both)
# MODAL_TOKEN_ID=...
# MODAL_TOKEN_SECRET=...

# ─── Observability / operations ───────────────────────────────────────────

# Sentry DSN for error reporting in the web UI. Optional.
# SENTRY_DSN=https://...

# OpenTelemetry OTLP endpoint. Optional.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── CLI (used by `gateway --remote` flows) ───────────────────────────────

# Override the base URL the CLI talks to. Default is http://localhost:3000
# (set to http://localhost:4000 if you use `gateway serve`'s default port).
# GATEWAY_BASE_URL=http://localhost:4000
